{
  "name": "inworld-mastra-design-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Voice agent that redesigns a live landing page — Mastra + Inworld realtime voice, with auth-gated Mastra Studio.",
  "license": "MIT",
  "author": "Inworld AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/inworld-ai/inworld-mastra-design-agent.git"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "mastra build --studio",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"public/*.{js,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"public/*.{js,css}\""
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@mastra/core": "1.38.0-alpha.5",
    "@mastra/editor": "^0.11.0-alpha.5",
    "@mastra/libsql": "^1.12.0-alpha.0",
    "@mastra/voice-inworld": "0.3.0-alpha.1",
    "hono": "^4.12.31",
    "mastra": "1.11.0-alpha.6",
    "tsx": "^4.21.0",
    "undici": "^7.28.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "brace-expansion@1": "^1.1.16",
    "brace-expansion@2": "^2.1.2",
    "fast-uri@3": "^3.1.4",
    "js-yaml@3": "^3.15.0",
    "shell-quote": "^1.9.0",
    "body-parser@2": "^2.3.0",
    "esbuild": "^0.28.1"
  }
}
